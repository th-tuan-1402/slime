{
  "name": "client",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "api:gen": "orval --config orval.config.mjs --tsconfig tsconfig.orval.json && node scripts/write-generated-api-index.mjs",
    "api:gen:check": "npm run api:gen && git diff --exit-code -- src/api/generated openapi/openapi.snapshot.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@nuxt/ui": "^2.19.3",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^3.17.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@storybook-vue/nuxt": "^9.0.1",
    "@storybook/addon-a11y": "9.0.5",
    "@storybook/addon-docs": "9.0.5",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "orval": "^7.5.0",
    "storybook": "9.0.5",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0",
    "typescript-eslint": "^8.18.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
